{
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.13"
  },
  "tasks": {
    "test": "deno task test:unit && deno task test:integration",
    "test:unit": "deno test --allow-net --allow-read --allow-env tests/unit/",
    "test:integration": "deno test --allow-net --allow-read --allow-env --allow-run --allow-write tests/integration/"
  },
  "fmt": {
    "include": [
      "tests/**/*.ts"
    ]
  },
  "lint": {
    "include": [
      "tests/**/*.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
