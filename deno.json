{
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.13"
  },
  "tasks": {
    "test": "deno test --allow-net --allow-read --allow-env tests/unit/"
  },
  "fmt": {
    "include": [
      "tests/**/*.ts"
    ]
  },
  "lint": {
    "include": [
      "tests/**/*.ts"
    ],
    "rules": {
      "tags": [
        "recommended"
      ]
    }
  }
}
