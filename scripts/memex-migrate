#!/usr/bin/env bash
# Exit codes:
#   0 = success
#   1 = migration failed during apply
#   2 = checksum drift detected for an already-applied migration
#   3 = preflight error
#
# Test-only hooks:
#   MEMEX_MIGRATE_DIR overrides the migration read path.
#   MEMEX_MIGRATE_MAX stops after the named version.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
MIGRATE_DIR="${MEMEX_MIGRATE_DIR:-${REPO_ROOT}/migrations}"
MIGRATE_MAX="${MEMEX_MIGRATE_MAX:-}"
PSQL_OVERRIDE="${PSQL:-psql}"

declare -a PSQL_CMD=()
declare -a MIGRATION_FILES=()
declare -a MIGRATION_VERSIONS=()
declare -a MIGRATION_CHECKSUMS=()
declare -a APPLIED_VERSIONS=()
declare -a APPLIED_CHECKSUMS=()

log() {
  printf '[memex-migrate] %s\n' "$*"
}

fail_prereq() {
  log "$*" >&2
  exit 3
}

fail_tamper() {
  log "$*" >&2
  exit 2
}

compute_sha256() {
  local path="$1"

  if command -v sha256sum >/dev/null 2>&1; then
    sha256sum "${path}" | awk '{print $1}'
    return
  fi

  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "${path}" | awk '{print $1}'
    return
  fi

  fail_prereq "missing checksum tool: need sha256sum or shasum"
}

psql_base() {
  "${PSQL_CMD[@]}" -X -v ON_ERROR_STOP=1 -U "${PGUSER}" -d "${PGDATABASE}" "$@"
}

psql_query() {
  psql_base -A -t "$@"
}

find_migration_index() {
  local version="$1"
  local i
  for ((i = 0; i < ${#MIGRATION_VERSIONS[@]}; i += 1)); do
    if [[ "${MIGRATION_VERSIONS[${i}]}" == "${version}" ]]; then
      printf '%s\n' "${i}"
      return 0
    fi
  done

  printf '%s\n' "-1"
}

find_applied_index() {
  local version="$1"
  local i
  for ((i = 0; i < ${#APPLIED_VERSIONS[@]}; i += 1)); do
    if [[ "${APPLIED_VERSIONS[${i}]}" == "${version}" ]]; then
      printf '%s\n' "${i}"
      return 0
    fi
  done

  printf '%s\n' "-1"
}

load_connection_settings() {
  if [[ -z "${PGHOST:-}" && -n "${MEMEX_TEST_DB_HOST:-}" ]]; then
    export PGHOST="${MEMEX_TEST_DB_HOST}"
  fi

  if [[ -z "${PGPORT:-}" && -n "${MEMEX_TEST_DB_PORT:-}" ]]; then
    export PGPORT="${MEMEX_TEST_DB_PORT}"
  fi

  if [[ -z "${PGUSER:-}" && -n "${MEMEX_TEST_DB_USER:-}" ]]; then
    export PGUSER="${MEMEX_TEST_DB_USER}"
  fi

  if [[ -z "${PGPASSWORD:-}" && -n "${MEMEX_TEST_DB_PASSWORD:-}" ]]; then
    export PGPASSWORD="${MEMEX_TEST_DB_PASSWORD}"
  fi

  if [[ -z "${PGDATABASE:-}" && -n "${MEMEX_TEST_DB_NAME:-}" ]]; then
    export PGDATABASE="${MEMEX_TEST_DB_NAME}"
  fi

  if [[ -z "${PGUSER:-}" ]]; then
    fail_prereq "missing database user: set PGUSER or MEMEX_TEST_DB_USER"
  fi

  if [[ -z "${PGDATABASE:-}" ]]; then
    fail_prereq "missing database name: set PGDATABASE or MEMEX_TEST_DB_NAME"
  fi
}

load_psql_command() {
  read -r -a PSQL_CMD <<< "${PSQL_OVERRIDE}"

  if (( ${#PSQL_CMD[@]} == 0 )); then
    fail_prereq "PSQL command is empty"
  fi

  if ! command -v "${PSQL_CMD[0]}" >/dev/null 2>&1; then
    fail_prereq "missing required command: ${PSQL_CMD[0]}"
  fi
}

discover_migrations() {
  local file

  if [[ ! -d "${MIGRATE_DIR}" ]]; then
    fail_prereq "migrations directory not found: ${MIGRATE_DIR}"
  fi

  while IFS= read -r file; do
    [[ -n "${file}" ]] || continue
    MIGRATION_FILES+=("${file}")
  done < <(
    find "${MIGRATE_DIR}" -maxdepth 1 -type f -name '[0-9][0-9][0-9][0-9]_*.sql' -print |
      LC_ALL=C sort
  )

  if (( ${#MIGRATION_FILES[@]} == 0 )); then
    fail_prereq "no migration files found in ${MIGRATE_DIR}"
  fi

  local expected=1
  for file in "${MIGRATION_FILES[@]}"; do
    local basename version expected_version checksum duplicate_index
    basename="$(basename "${file}")"
    version="${basename%%_*}"
    expected_version="$(printf '%04d' "${expected}")"

    duplicate_index="$(find_migration_index "${version}")"
    if (( duplicate_index >= 0 )); then
      fail_prereq "duplicate migration version ${version}: ${MIGRATION_FILES[${duplicate_index}]} and ${file}"
    fi

    if [[ "${version}" != "${expected_version}" ]]; then
      fail_prereq "migration version gap: expected ${expected_version}, found ${version} (${basename})"
    fi

    if [[ ! -r "${file}" ]]; then
      fail_prereq "migration file is not readable: ${file}"
    fi

    checksum="$(compute_sha256 "${file}")"
    MIGRATION_VERSIONS+=("${version}")
    MIGRATION_CHECKSUMS+=("${checksum}")
    ((expected += 1))
  done
}

load_applied_migrations() {
  local schema_exists
  if ! schema_exists="$(psql_query -c "SELECT to_regclass('public.schema_migrations') IS NOT NULL;")"; then
    fail_prereq "failed to query schema_migrations preflight"
  fi

  schema_exists="$(tr -d '[:space:]' <<< "${schema_exists}")"
  if [[ "${schema_exists}" != "t" ]]; then
    return
  fi

  local rows
  if ! rows="$(psql_query -F $'\t' -c "SELECT version, COALESCE(checksum, '') FROM schema_migrations ORDER BY version;")"; then
    fail_prereq "failed to read schema_migrations"
  fi

  if [[ -z "${rows}" ]]; then
    return
  fi

  while IFS=$'\t' read -r version checksum; do
    [[ -n "${version}" ]] || continue
    APPLIED_VERSIONS+=("${version}")
    APPLIED_CHECKSUMS+=("${checksum}")
  done <<< "${rows}"
}

validate_applied_checksums() {
  local i version applied_index
  for ((i = 0; i < ${#MIGRATION_FILES[@]}; i += 1)); do
    version="${MIGRATION_VERSIONS[${i}]}"
    applied_index="$(find_applied_index "${version}")"

    if (( applied_index < 0 )); then
      continue
    fi

    if [[ "${APPLIED_CHECKSUMS[${applied_index}]}" != "${MIGRATION_CHECKSUMS[${i}]}" ]]; then
      fail_tamper "checksum mismatch ${version}"
    fi

    log "already applied ${version}"
  done

  for ((i = 0; i < ${#APPLIED_VERSIONS[@]}; i += 1)); do
    version="${APPLIED_VERSIONS[${i}]}"
    if (( $(find_migration_index "${version}") < 0 )); then
      fail_tamper "checksum mismatch ${version}: migration file missing from ${MIGRATE_DIR}"
    fi
  done
}

apply_migration() {
  local version="$1"
  local file="$2"
  local checksum="$3"
  local status

  set +e
  {
    cat "${file}"
    printf "\nINSERT INTO schema_migrations (version, checksum) VALUES ('%s', '%s');\n" "${version}" "${checksum}"
  } | psql_base --single-transaction
  status=$?
  set -e

  if (( status != 0 )); then
    log "failed version ${version}" >&2
    exit 1
  fi

  log "applied ${version}"
}

main() {
  load_connection_settings
  load_psql_command
  discover_migrations
  load_applied_migrations
  validate_applied_checksums

  local applied_any=0
  local i file version checksum applied_index
  for ((i = 0; i < ${#MIGRATION_FILES[@]}; i += 1)); do
    file="${MIGRATION_FILES[${i}]}"
    version="${MIGRATION_VERSIONS[${i}]}"

    if [[ -n "${MIGRATE_MAX}" && "${version}" > "${MIGRATE_MAX}" ]]; then
      break
    fi

    applied_index="$(find_applied_index "${version}")"
    if (( applied_index >= 0 )); then
      continue
    fi

    checksum="${MIGRATION_CHECKSUMS[${i}]}"
    apply_migration "${version}" "${file}" "${checksum}"
    applied_any=1
  done

  if (( applied_any == 0 )); then
    log "no pending migrations"
  fi
}

main "$@"
